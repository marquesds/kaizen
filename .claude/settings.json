{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "kaizen ingest hook --source claude",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": ".cursor/hooks/cap-bash.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "kaizen ingest hook --source claude",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "kaizen ingest hook --source claude",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "cargo run --bin kaizen -- ingest hook --source claude",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "kaizen ingest hook --source claude",
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "WebFetch(*)",
      "Glob(*)",
      "Grep(*)"
    ]
  }
}