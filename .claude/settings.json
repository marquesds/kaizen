{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": ".cursor/hooks/cap-bash.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "WebFetch(*)",
      "Glob(*)",
      "Grep(*)"
    ]
  }
}